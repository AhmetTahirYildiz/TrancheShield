# TrancheShield dashboard — public config.
# Copy to `.env.local` and adjust. Every var here is bundled into the browser
# (NEXT_PUBLIC_ prefix), so it MUST be public-safe. Never put a private key here.
#
# All values are optional: if a var is unset, the app falls back to the live
# testnet deployment baked into lib/config.ts, so the dashboard works out of the box.

# --- Network ---------------------------------------------------------------
# Unichain Sepolia (chain 1301) RPC. Public endpoint works; swap in your own
# (Alchemy/dRPC) if you hit rate limits during the demo.
NEXT_PUBLIC_UNICHAIN_RPC=https://sepolia.unichain.org

# --- Deployed contracts (Unichain Sepolia) ---------------------------------
NEXT_PUBLIC_HOOK_ADDRESS=0x696d7e04c2637630fec303628bf774ae57c48fc0
NEXT_PUBLIC_RECEIVER_ADDRESS=0xdd3da7354ce7807dbe8ae50eae83cd9c7c7ff9cd
NEXT_PUBLIC_RESERVE_ADDRESS=0x3de4acc32c8cf9228c63d673b7cda01f2d17ae6d

# Reactive Smart Contract on Lasna (chain 5318007) — shown for provenance only.
NEXT_PUBLIC_RSC_ADDRESS=0xC2D2eDA8677c93172A0acE228Eb8CB58621705dC

# Official Uniswap v4 Quoter deployed against the live PoolManager — used for the
# live "router quote" panel (proves the hook is quotable/routable).
NEXT_PUBLIC_QUOTER_ADDRESS=0x82e1dd8da6b484c7a5d52fd661023f10f780ced3

# --- Demo pool -------------------------------------------------------------
NEXT_PUBLIC_POOL_ID=0x3296bf4dcea4911b02a1df529a67457118779175048a0689f5e2bb38259da195
NEXT_PUBLIC_TOKEN0=0x9903fa2e3c3291cffbde6958676adc92737a82a0
NEXT_PUBLIC_TOKEN1=0xb9cc9045d84485e5864b5ef2ecc77931824b89e2

# Interactive demo pool (script/SeedInteractivePool.s.sol) — a FRESH pool that
# starts LOW so the Interactive tab can drive swaps and flip it to CRISIS live.
# Re-run the seed for a fresh LOW pool before recording, then update these.
NEXT_PUBLIC_INTERACTIVE_POOL_ID=0x863ae83865d5e214660cad63d93c6f84279137c9fb4ad91f4ee97aecae4f9e5e
NEXT_PUBLIC_INTERACTIVE_TOKEN0=0x1363436d53e895207d2c3778f3675c321babb913
NEXT_PUBLIC_INTERACTIVE_TOKEN1=0xb5df790f62d841ea404bef0e2ac592c063792d6b

# --- Event scanning --------------------------------------------------------
# The activity feed + volatility chart read logs with eth_getLogs for POOL_ID.
#
# IMPORTANT: a FIXED historical window ages out. Public Unichain RPCs only serve
# eth_getLogs for a recent block range, so as the chain advances past an old
# FROM/TO window the feed silently goes empty (no error, just no rows). For a
# LIVE demo, point POOL_ID at the interactive pool (above) and leave FROM/TO
# BLANK — the app then scans the most recent NEXT_PUBLIC_EVENT_LOOKBACK blocks,
# which always works and shows the swaps/callbacks you just produced.
# NEXT_PUBLIC_EVENT_FROM_BLOCK=
# NEXT_PUBLIC_EVENT_TO_BLOCK=
NEXT_PUBLIC_EVENT_LOOKBACK=9000

# Poll interval (ms) for the live risk-state read.
NEXT_PUBLIC_POLL_INTERVAL_MS=6000

# --- Real on-chain proof scenario -----------------------------------------
# The OnChainProof panel reads the genuine PositionClosed(ilShortfall,
# compensation) event produced by script/RealComparison.s.sol. It resolves the
# event from this transaction RECEIPT (by hash), NOT eth_getLogs — so the proof
# never ages out of an RPC's log window no matter how far the chain advances.
NEXT_PUBLIC_SCENARIO_TX_HASH=0x41f83c694e25cf8459e470dde3b519cfa8b419f9e1daeb14cc3ff383cdff59ed
NEXT_PUBLIC_SCENARIO_POOL_ID=0x0fe678433179b93a0b6f4ced6c23ad08413ccc7b657e292e3dc925518af6cbb9
